# Root environment for docker-compose.
# Copy to ".env" and adjust as needed: cp .env.example .env

# PostgreSQL
POSTGRES_USER=tms_user
POSTGRES_PASSWORD=tms_password
POSTGRES_DB=tms_db

# API
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8080

# Web (baked into the frontend bundle at build time)
VITE_API_URL=http://localhost:5000/api
